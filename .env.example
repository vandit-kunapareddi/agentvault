# PostgreSQL connection string.
# Local dev (Docker): postgresql://agentvault:agentvault@localhost:5432/agentvault?schema=public
# Production: use the Railway Postgres connection string.
DATABASE_URL="postgresql://agentvault:agentvault@localhost:5432/agentvault?schema=public"
# Must be identical in the dashboard and checkpoint (one signs credentials, the other verifies them).
JWT_SECRET="replace-me-with-a-long-random-string"

# Slack escalations (optional — leave blank to disable)
# Get a webhook URL from https://api.slack.com/apps -> Incoming Webhooks
SLACK_WEBHOOK_URL=
# From your Slack app's Basic Information page; required for /slack/interactivity callback
SLACK_SIGNING_SECRET=

# How long the checkpoint waits for human resolution before auto-blocking
ESCALATION_TIMEOUT_MS=60000

# Minimum trust score (0-100) an agent must clear to make a payment
MIN_TRUST_SCORE=50

# Escalate further payments once an agent exceeds this many escalations in an hour
ESCALATION_RATE_LIMIT=3

# Dashboard → checkpoint forwarder + dashboard link inside Slack messages
CHECKPOINT_INTERNAL_URL=http://localhost:4000
DASHBOARD_URL=http://localhost:3000
