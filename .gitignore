# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
/out/

# production
/build
apps/*/dist
packages/*/dist

# prisma (committed migrations live in prisma/migrations/)
prisma/*.db
prisma/*.db-journal

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.*
!.env.example

# local dev tooling
.claude/
.scratch/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local-only artifacts (demo recordings, wallet keys, etc.)
*.mp4
wallet key/
