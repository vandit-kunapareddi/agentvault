{
  "name": "agentvault",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:dashboard": "npm run dev -w @agentvault/dashboard",
    "dev:checkpoint": "npm run dev -w @agentvault/checkpoint",
    "build:dashboard": "npm run build -w @agentvault/dashboard",
    "build:checkpoint": "npm run build -w @agentvault/checkpoint",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  }
}
