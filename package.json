{
  "name": "agentvault",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n checkpoint,dashboard -c blue,magenta \"npm:dev:checkpoint\" \"npm:dev:dashboard\"",
    "dev:dashboard": "npm run dev -w @agentvault/dashboard",
    "dev:checkpoint": "npm run dev -w @agentvault/checkpoint",
    "build:dashboard": "npm run build -w @agentvault/dashboard",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "seed": "tsx scripts/seed.ts",
    "demo:fire": "tsx scripts/demo-fire.ts",
    "wallet:bootstrap": "tsx scripts/wallet-bootstrap.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p apps/checkpoint/tsconfig.json && tsc --noEmit -p apps/dashboard/tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^20",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "prisma": "^6.0.0"
  }
}
