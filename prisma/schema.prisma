generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id              String        @id @default(cuid())
  name            String
  walletAddress   String        @unique
  trustTier       String        @default("verified")
  trustScore      Float         @default(85)
  trustProviderId String?
  parentAgentId   String?
  parent          Agent?        @relation("AgentTree", fields: [parentAgentId], references: [id])
  children        Agent[]       @relation("AgentTree")
  credential      String?
  authorizedBy    String
  dailyCap        Float
  perTxLimit      Float
  approvedVendors String
  expiresAt       DateTime
  createdAt       DateTime      @default(now())
  transactions    Transaction[]
}

model Transaction {
  id          String        @id @default(cuid())
  agentId     String
  agent       Agent         @relation(fields: [agentId], references: [id])
  vendor      String
  amount      Float
  status      String
  protocol    String        @default("x402")
  trustTier   String?
  reason      String?
  createdAt   DateTime      @default(now())
  escalations Escalation[]
}

model Escalation {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  status        String
  notifiedAt    DateTime?
  resolvedAt    DateTime?
  resolvedBy    String?
  createdAt     DateTime    @default(now())
}
